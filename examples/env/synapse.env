# linkora Environment Variables
# Copy this file to your environment or source it
# Usage: export $(cat linkora.env | xargs)

# =============================================================================
# Core Configuration
# =============================================================================

# Root directory for all workspaces (optional, auto-detected if not set)
# linkora_ROOT=/path/to/linkora/root

# Active workspace name (overrides default_workspace in config)
# linkora_WORKSPACE=my-workspace

# =============================================================================
# LLM API Keys
# =============================================================================

# Primary LLM API key (used by default)
linkora_LLM_API_KEY=

# Fallback: DeepSeek API key
DEEPSEEK_API_KEY=

# Fallback: OpenAI API key
OPENAI_API_KEY=

# =============================================================================
# Data Source API Keys
# =============================================================================

# OpenAlex API key (for journal fetching)
OPENALEX_API_KEY=

# Zotero integration
ZOTERO_LIBRARY_ID=
ZOTERO_API_KEY=

# MinerU PDF parsing
MINERU_API_KEY=

# =============================================================================
# Optional: Custom Embedding Model
# =============================================================================

# Override default embedding model
# linkora_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# Embedding model cache directory
# linkora_EMBED_CACHE=~/.cache/modelscope/hub/models
